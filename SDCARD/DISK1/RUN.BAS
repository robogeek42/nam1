10 GOSUB 1200 ; load data
20 MODE 2
30 SCOL 15,1
40 CLS
45 PRINT " ======== Load Image ========"
50 FOR I=0 TO N-1
60 CURS 0,I+2:PRINT IX(I);" ";
70 CURS 5,I+2:PRINT D$(I);
80 NEXT I
90 CURS 2,N+2+2 : PRINT"Choose Image No ";
100 INPUT M
110 IF M=0 THEN GOTO 200
120 IF M <1 OR M>N THEN GOTO 90
130 CLS
150 LOADIMG F$(M-1)
160 K=GETKEY
170 GOTO 40

200 MODE 0
220 END


1200 REM Load data
1205 N=13
1210 DIM IX(N), F$(N), D$(N)
1220 FOR I=0 TO N-1
1230 READ IX(I),F$(I),D$(I)
1240 NEXT I
1250 RETURN


