
5 REM visual sort
10 N=10
20 DIM S$(N): DIM X(N)
30 REM load data and index
40 FOR I=0 TO N-1
50 READ S$(I): X(I)=I
60 NEXT I
100 GOSUB 200 : REM print
110 INPUT Q$
120 GOSUB 500 : REM sort
130 IF NS=1 THEN GOTO 150
140 GOTO 100
150 PRINT "Done!"
199 END

200 REM print 
210 CLS
220 FORI=0 TO N-1
230 CURS 3,I
240 PRINT S$(X(I))
250 NEXT I
260 RETURN

300 REM swap positions A B in X()
302 REM PRINT "swap ";A;" ";B
310 TMP=X(B)
320 X(B)=X(A)
330 X(A)=TMP
390 RETURN

400 REM compare strings at pos A B in X()
402 REM PRINT "comp ";A;"(";S$(X(A));") to ";B;"(";S$(X(B));")"
405 C=0 : REM same, C=1 A after B, C=-1 A before B
410 S1$=S$(X(A)) : S2$=S$(X(B))
420 L=MIN(LEN(S1$), LEN(S2$))
430 I=1
440 IF ASC(MID$(S1$,I,1)) > ASC(MID$(S2$,I,1)) THEN C=1 : GOTO 490
450 IF ASC(MID$(S1$,I,1)) < ASC(MID$(S2$,I,1)) THEN C=-1 : GOTO 490
460 I=I+1: IF I <= L GOTO 440
490 RETURN

500 REM sort
505 NS=1
510 FOR J=0 TO N-2
520 A=J : B=J+1 : GOSUB 400 : REM compare
530 IF C=1 THEN NS=0 : GOSUB 300 : REM swap
540 NEXT J
590 RETURN

