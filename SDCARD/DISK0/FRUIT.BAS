
5 REM visual sort
10 N=10
20 MODE 4 : SCOL 15,1 : REM ensures black border
30 DIM S$(N): DIM X(N) : DIM CO(N)
40 REM load name, colour and index
50 FOR I=0 TO N-1
60 READ S$(I): X(I)=I
70 READ CO(I)
80 NEXT I
100 GOSUB 200 : REM print
110 Q=GETKEY:Q$=CHR$(Q):PRINT Q$
115 IF Q$="q" OR Q$="Q" THEN END
120 GOSUB 500 : REM sort
130 IF NS=1 THEN GOTO 150
140 GOTO 110
150 COL 15,1
160 CURS 0,20:PRINT "Done!"
199 END
200 REM print 
210 COL 15,1 : CLS
220 FORI=0 TO N-1
230 CURS 2,I
240 COL 1, CO(X(I))
250 PRINT S$(X(I))
260 NEXT I
290 RETURN
300 REM swap positions A B in X()
302 REM PRINT "swap ";A;" ";B
310 REM COL 15,1 : CURS 0,A : PRINT"*";
320 REM COL 15,1 : CURS 0,B : PRINT"*";
330 TMP=X(B)
340 X(B)=X(A)
350 X(A)=TMP
390 RETURN
400 REM compare strings at pos A B in X()
405 C=0 : REM same, C=1 A after B, C=-1 A before B
410 S1$=S$(X(A)) : S2$=S$(X(B))
420 L=MIN(LEN(S1$), LEN(S2$))
430 I=1
440 IF ASC(MID$(S1$,I,1)) > ASC(MID$(S2$,I,1)) THEN C=1 : GOTO 490
450 IF ASC(MID$(S1$,I,1)) < ASC(MID$(S2$,I,1)) THEN C=-1 : GOTO 490
460 I=I+1: IF I <= L GOTO 440
490 RETURN
500 REM sort
505 NS=1
510 FOR J=0 TO N-2
520 A=J : B=J+1 : GOSUB 400 : REM compare
530 IF C=1 THEN NS=0 : GOSUB 600: GOSUB 300 
540 NEXT J
590 RETURN
600 REM swap anim
REM move B across
610 FOR J=1TO11
612 COL 15,1:CURS 2,B:PRINT SPC(J);
614 COL 1, CO(X(B)):PRINT S$(X(B));
616 DELAY 10
618 NEXTJ
REM Move B up (A stays)
620 DELAY 100: CURS 2,A:COL 1,CO(X(A)):PRINT S$(X(A));
622 CURS 13,A:COL 1,CO(X(B)):PRINT S$(X(B));
624 CURS 2,B:COL15,1:PRINT SPC(26);
REM Move A down
626 DELAY 100: CURS 2,A:COL 15,1:PRINT SPC(11);
628 CURS 2,B:COL 1,CO(X(A)):PRINT S$(X(A));
REM move B back in on line A
640 FOR J=11TO0 STEP -1
642 COL 15,1:CURS 2,A:PRINT SPC(J);
644 COL 1, CO(X(B)):PRINT S$(X(B));:COL 15,1: PRINT SPC(11);
646 DELAY 20
648 NEXTJ
650 RETURN 

