10 REM Bresnham line algo
20 MODE 4
30 FOR I=1 TO 8
40 READ X1,Y1,X2,Y2
45 CURS0,0:PRINT SPC(40);:CURS0,1:PRINT SPC(40);
50 GOSUB 300
55 DELAY 100:K=GETKEY
60 NEXT I

148 CURS 0,2
149 END
180 DATA 100,100,160,140
181 DATA 100,100,140,160
182 DATA 100,100,10,60
183 DATA 100,100,80,30
184 DATA 100,100,170,70
185 DATA 100,100,120,30
186 DATA 100,100,30,110
187 DATA 100,100,80,180

300 REM choose
305 CURS 0,0:PRINT "(";X1;",";Y1;") -> (";X2;",";Y2;")";
310 XD=X2-X1 : YD=Y2-Y1
320 IF XD<=0 AND YD<=0 THEN GOSUB 380 : GOTO 350
330 IF YD<=0 THEN GOTO 360
340 IF XD<=0 THEN GOSUB 380 : GOTO 360

REM both Xd and Yd +ve or both -ve
350 IF ABS(XD)>ABS(YD) THEN GOTO 400 ELSE GOTO 500
REM one of Xd or Yd -ve
360 IF ABS(XD)>ABS(YD) THEN GOTO 600 ELSE GOTO 700

380 REM swap X1,Y1,X2,Y2
382 T=X2:X2=X1:X1=T
384 T=Y2:Y2=Y1:Y1=T
386 RETURN

400 REM +ve X and Y XD>YD
405 CURS 0,1:PRINT"+X +Y and XD>YD";
410 XD=X2-X1 : YD=Y2-Y1
420 M=2*YD
430 SE=M-XD : REM Slope Err init
440 Y=Y1:FOR X=X1 TO X2 STEP 1
450 SE=SE+M
460 IF SE>=0 THEN SE=SE-2*XD : Y=Y+1
470 PLOT X,Y
480 NEXT
490 RETURN

500 REM +ve X and Y XD<YD
505 CURS 0,1:PRINT"+X +Y and XD<YD";
510 XD=X2-X1 : YD=Y2-Y1
520 M=2*XD
530 SE=M-YD
540 X=X1:FOR Y=Y1 TO Y2 STEP 1
550 SE=SE+M
560 IF SE>=0 THEN SE=SE-2*YD : X=X+1
570 PLOT X,Y
580 NEXT
590 RETURN

600 REM +ve X and -ve Y abs(XD)>abs(YD)
605 CURS 0,1:PRINT"+X -Y and abs(XD)>abs(YD)";
610 XD=X2-X1 : YD=Y1-Y2
620 M=2*YD
630 SE=M+XD
640 Y=Y1:FOR X=X1 TO X2 STEP 1
650 SE=SE-M
660 IF SE<0 THEN SE=SE+2*XD : Y=Y-1
670 PLOT X,Y
680 NEXT
690 RETURN

700 REM +ve X and -ve Y abs(XD)<abs(YD)
705 CURS 0,1:PRINT"+X -Y and abs(XD)<abs(YD)";
710 XD=X2-X1 : YD=Y1-Y2
720 M=2*XD
730 SE=M+YD
740 X=X1:FOR Y=Y1 TO Y2 STEP -1
750 SE=SE-M
760 IF SE<0 THEN SE=SE+2*YD : X=X+1
770 PLOT X,Y
780 NEXT
790 RETURN
