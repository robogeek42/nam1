10 MODE 4
20 CURS 9,0:COL6,1:PRINT"Sin";:COL15,1:PRINT"/";
25 COL4,1:PRINT"Cos";:COL15,1:PRINT" Plot";
30 P=TWOPI/128
40 Q=TWOPI/128
50 FOR X=0 TO 255 STEP 0.5
60 Y1=SIN(X*P)*80+96
70 GCOL 6,1
80 PLOT ABS(X),ABS(Y1)
90 Y2=COS(X*Q)*80+96
100 GCOL 4,1
110 PLOT ABS(X),ABS(Y2)
120 NEXT
130 GCOL11,1
140 FOR X=0TO255:PLOTX,96:NEXT
150 DELAY 1000 : K=GETKEY
160 CURS 0,2
