5 R=RND(1881)
10 MODE 4
20 FOR I=0 TO 4
30 X1=RND(0)*255
40 Y1=RND(0)*191
50 X2=RND(0)*255
60 Y2=RND(0)*191
70 GOSUB 200 
80 NEXT I
90 END

200 REM line
210 XD=X2-X1
220 YD=Y2-Y1
230 IF YD > XD GOTO 400
260 YI=YD/ABS(XD) : Y=Y1
264 IF X2>X1 THEN XI=1 ELSE XI=-1
265 CURS0,0:PRINTX1,Y1:PRINTX2,Y2:PRINTXD,YD:PRINTYI
266 K=GETKEY
270 FOR X=X1 TO X2 STEP XI
280 PLOT ABS(X),ABS(Y)
290 Y=Y+YI
300 NEXT X
310 RETURN

400 XI=XD/ABS(YD) : X=X1
404 IF Y2>Y1 THEN YI=1 ELSE YI=-1
405 CURS0,0:PRINTX1,Y1:PRINTX2,Y2:PRINTXD,YD:PRINTXI
406 K=GETKEY
410 FOR Y=Y1 TO Y2 STEP YI
420 PLOT ABS(X),ABS(Y)
430 X=X+XI
440 NEXT Y
450 RETURN
